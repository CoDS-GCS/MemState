# Copy to .env and fill in. Never commit .env.

# MemState API (optional)
# MEMSTATE_API_KEY=

# Groq Cloud (https://console.groq.com) — for Assistant when provider is Groq
GROQ_API_KEY=

# Ollama (local) — optional overrides
# MEMSTATE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# MEMSTATE_OLLAMA_MODEL=llama3.2:latest

# Assistant chat: how many dialogue turns (user + assistant) to send for intent/context (1–64).
# MEMSTATE_CHAT_INTENT_TURNS=8
# Max LLM↔API rounds while the model keeps calling tools (reorganize merges may need many; 1–256).
# MEMSTATE_CHAT_MAX_TOOL_ROUNDS=32
# Query intent: bump per-field salience when read tools return fields (cap MEMSTATE_FIELD_SALIENCE_MAX).
# MEMSTATE_QUERY_FIELD_SALIENCE_BUMP=0.1
# MEMSTATE_FIELD_SALIENCE_MAX=10
