# Copy to .env and fill in. Never commit .env.

# MemState API (optional)
# MEMSTATE_API_KEY=

# Groq Cloud (https://console.groq.com) — for Assistant when provider is Groq
GROQ_API_KEY=
# Whisper model for UI mic → POST /api/ui/transcribe or /api/llm/transcribe (same key as above).
# MEMSTATE_GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Ollama (local) — optional overrides
# MEMSTATE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# MEMSTATE_OLLAMA_MODEL=llama3.2:latest

# Assistant chat: how many dialogue turns (user + assistant) to send for intent/context (1–64).
# MEMSTATE_CHAT_INTENT_TURNS=8
# Max LLM↔API rounds while the model keeps calling tools (reorganize merges may need many; 1–256).
# MEMSTATE_CHAT_MAX_TOOL_ROUNDS=32
# Study long-document ingest: when the last user message exceeds this length and intent is ingest/both,
# the server runs the Study pipeline (hierarchy + phase A sandbox + phase B integration with memory).
# MEMSTATE_CHAT_CHUNK_THRESHOLD_CHARS=10000
# Per-phase tool budget for Study phase A (and legacy overlap chunking if re-enabled elsewhere).
# MEMSTATE_CHAT_CHUNK_PER_SEGMENT_TOOL_ROUNDS=72
# Pause between Study phase A and B (seconds) to reduce Groq TPM bursts; 0 disables.
# MEMSTATE_STUDY_PHASE_DELAY_SECONDS=8
# Groq: retries after rate limit (429 / rate_limit_exceeded); max attempts and cap per sleep.
# MEMSTATE_GROQ_RATE_LIMIT_MAX_RETRIES=20
# MEMSTATE_GROQ_RATE_LIMIT_BACKOFF_CAP_SECONDS=120
# Legacy overlap chunk settings (unused by default Study flow; kept for compatibility).
# MEMSTATE_CHAT_CHUNK_MAX_CHARS=10000
# MEMSTATE_CHAT_CHUNK_OVERLAP=800
# Query intent: bump per-field salience when read tools return fields (cap MEMSTATE_FIELD_SALIENCE_MAX).
# MEMSTATE_QUERY_FIELD_SALIENCE_BUMP=0.1
# MEMSTATE_FIELD_SALIENCE_MAX=10
